# Telegram example:
# Copy the block you need into `.env`.
# BRIDGE_PLATFORM=telegram
# CODEX_WORKDIR=/abs/path/to/your/project
# CODEX_BIN=/abs/path/to/your/codex
# CODEX_FULL_AUTO=1
# CODEX_SANDBOX=workspace-write
# TELEGRAM_BOT_TOKEN=123456789:replace_me
# ALLOWED_TELEGRAM_USER_IDS=123456789

# Feishu / Lark example:
# BRIDGE_PLATFORM=feishu
# CODEX_WORKDIR=/abs/path/to/your/project
# CODEX_BIN=/abs/path/to/your/codex
# CODEX_FULL_AUTO=1
# CODEX_SANDBOX=workspace-write
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=replace_me
# FEISHU_ALLOW_FROM=ou_xxx
# FEISHU_SUBSCRIPTION_MODE=websocket

# Telegram optional:
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# TELEGRAM_API_ROOT=https://api.telegram.org
# TELEGRAM_FILE_ROOT=https://api.telegram.org/file

# Feishu / Lark optional:
# FEISHU_DOMAIN=feishu
# FEISHU_VERIFICATION_TOKEN=replace_me
# FEISHU_WEBHOOK_HOST=127.0.0.1
# FEISHU_WEBHOOK_PORT=3000
# FEISHU_WEBHOOK_PATH=/feishu/events
# FEISHU_GROUP_POLICY=disabled
# FEISHU_GROUP_ALLOW_FROM=oc_xxx
# FEISHU_REQUIRE_MENTION=1
# FEISHU_STREAMING=1
# FEISHU_STREAM_UPDATE_MS=800

# Shared optional:
# BRIDGE_STATE_DIR=/root/.codex-bridge
# CODEX_MODEL=gpt-5.4
# CODEX_PROFILE=default
# CODEX_SKIP_GIT_REPO_CHECK=0
# TELEGRAM_CODEX_STATE_DIR=/root/.codex-telegram-bridge
# FEISHU_STATE_DIR=/root/.codex-feishu-bridge
# MAX_PROMPT_CHARS=16000
# MAX_OUTPUT_CHARS=12000
