# This repo has three parallel modes:
# - Telegram mode
# - Feishu / Lark mode
# - Remote mode
# Copy only the block you need into `.env`.

# Telegram example:
# BRIDGE_PLATFORM=telegram
# CODEX_WORKDIR=/abs/path/to/your/project
# CODEX_BIN=/abs/path/to/your/codex
# CODEX_APPROVAL_MODE=on-request
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_BYPASS_APPROVALS_AND_SANDBOX=0
# TELEGRAM_BOT_TOKEN=123456789:replace_me
# ALLOWED_TELEGRAM_USER_IDS=123456789

# Feishu / Lark example:
# BRIDGE_PLATFORM=feishu
# CODEX_WORKDIR=/abs/path/to/your/project
# CODEX_BIN=/abs/path/to/your/codex
# CODEX_APPROVAL_MODE=on-request
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_BYPASS_APPROVALS_AND_SANDBOX=0
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=replace_me
# FEISHU_ALLOW_FROM=ou_xxx
# FEISHU_SUBSCRIPTION_MODE=websocket

# Remote client example:
# Use this on the public hub machine.
# REMOTE_CLIENT_HOST=0.0.0.0
# REMOTE_CLIENT_PORT=8789
# REMOTE_SHARED_SECRET=replace_me
# REMOTE_CLIENT_API_TOKEN=replace_me

# Remote server example:
# Use this on the local Codex machine.
# REMOTE_CLIENT_URL=https://your-client.example.com
# REMOTE_SERVER_ID=my-laptop
# REMOTE_SHARED_SECRET=replace_me
# CODEX_WORKDIR=/abs/path/to/your/project
# CODEX_BIN=/abs/path/to/your/codex
# CODEX_APPROVAL_MODE=on-request
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_BYPASS_APPROVALS_AND_SANDBOX=0

# Telegram optional:
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# TELEGRAM_API_ROOT=https://api.telegram.org
# TELEGRAM_FILE_ROOT=https://api.telegram.org/file

# Feishu / Lark optional:
# FEISHU_DOMAIN=feishu
# FEISHU_VERIFICATION_TOKEN=replace_me
# FEISHU_WEBHOOK_HOST=127.0.0.1
# FEISHU_WEBHOOK_PORT=3000
# FEISHU_WEBHOOK_PATH=/feishu/events
# FEISHU_GROUP_POLICY=open
# FEISHU_GROUP_ALLOW_FROM=oc_xxx
# FEISHU_REQUIRE_MENTION=0
# FEISHU_BOT_OPEN_ID=ou_xxx
# If omitted, the bridge can auto-learn it from the first clear group @mention event.
# FEISHU_USER_WORKDIR_MAP=ou_alice=/work/project-a;ou_bob=/work/project-b
# FEISHU_STREAMING=1
# FEISHU_STREAM_UPDATE_MS=800

# Shared optional:
# BRIDGE_STATE_DIR=/root/.codex-bridge
# Compatibility aliases:
# CODEX_FULL_AUTO=1
# CODEX_SANDBOX=workspace-write
# CODEX_MODEL=gpt-5.4
# CODEX_PROFILE=default
# CODEX_SKIP_GIT_REPO_CHECK=0
# TELEGRAM_CODEX_STATE_DIR=/root/.codex-telegram-bridge
# FEISHU_STATE_DIR=/root/.codex-feishu-bridge
# REMOTE_CLIENT_STATE_DIR=/root/.codex-remote-client
# REMOTE_SERVER_STATE_DIR=/root/.codex-remote-server
# REMOTE_AGENT_PATH=/remote/agent/connect
# REMOTE_EVENT_PATH=/remote/agent/events
# REMOTE_API_PREFIX=/remote/api
# REMOTE_REQUEST_TIMEOUT_MS=900000
# REMOTE_RECONNECT_DELAY_MS=3000
# REMOTE_PROGRESS_UPDATE_MS=1000
# MAX_PROMPT_CHARS=16000
# MAX_OUTPUT_CHARS=12000
